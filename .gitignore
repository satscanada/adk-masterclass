# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# Distribution / packaging (repo root only; ui uses its own .gitignore)
/build/
/dist/
*.egg-info/
.eggs/
*.egg

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Type checkers / linters
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints

# pyenv / local
.python-version

# Secrets and local env (commit only .env.example templates, e.g. root + ui/)
# `.env` matches that filename in any directory; `.env.*` catches .env.local, .env.production, etc.
.env
.env.*
!.env.example

# Private keys / certs (never commit)
*.pem
*.p12
id_rsa
id_ed25519
id_ecdsa

# OS
.DS_Store
Thumbs.db
