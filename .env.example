# Base URL of your LiteLLM/OpenAI-compatible endpoint.
# Both of these forms work:
#   http://127.0.0.1:4000
#   http://127.0.0.1:4000/v1
LITELLM_API_BASE=http://127.0.0.1:4000/v1

# API key for the endpoint.
# If your local proxy ignores auth, you can still leave a dummy value like "not-needed".
LITELLM_API_KEY=not-needed

# The model name exactly as your endpoint expects it in chat/completions.
LITELLM_MODEL=gemini-3-flash-preview

# Optional: mirrors the max_tokens field from your curl payload.
LITELLM_MAX_TOKENS=32

# Optional: provider prefix used by LiteLLM. For OpenAI-compatible endpoints, keep "openai".
LITELLM_PROVIDER=openai

# Optional: ADK app name shown in session metadata.
ADK_APP_NAME=simple_litellm_agent

# Optional: system instruction for the demo agent.
AGENT_INSTRUCTION=You are a helpful beginner demo agent built with Google ADK. Answer clearly and briefly.

# Optional: CORS origins for the agent API.
AGENT_API_CORS_ORIGINS=http://localhost:8513,http://127.0.0.1:8513

# Meteosource free API key for Module 05 (advanced_agent / weather tools).
# https://www.meteosource.com/client/#pricing
WEATHER_API_KEY=

# Module 09 Celery + Redis (optional)
# Prefer full URL when connecting to managed or remote Redis:
# MODULE09_CELERY_REDIS_URL=redis://:password@10.20.30.40:6380/0
MODULE09_CELERY_REDIS_URL=
#
# Or provide host/port/db fields (used when URL is not set):
MODULE09_REDIS_HOST=localhost
MODULE09_REDIS_PORT=6379
MODULE09_REDIS_DB=0
# MODULE09_REDIS_PASSWORD=

# Module 10 MCP client (Redis MCP server process)
# Override these if your Redis MCP server command differs.
MODULE10_MCP_COMMAND=uvx
MODULE10_MCP_ARGS=--from redis-mcp-server@latest redis-mcp-server
MODULE10_MCP_TIMEOUT=20

# Module 10 Redis connection (used to compose redis:// URL passed to MCP as an arg)
# Prefer full URL when available:
# MODULE10_REDIS_URL=redis://:password@127.0.0.1:6379/0
MODULE10_REDIS_URL=
MODULE10_REDIS_HOST=127.0.0.1
MODULE10_REDIS_PORT=6379
MODULE10_REDIS_DB=0
# MODULE10_REDIS_USERNAME=
# MODULE10_REDIS_PASSWORD=

# Module 11 MCP server (OpenAPI artifact explorer)
# Leave MODULE11_SPECS_DIR empty to use the bundled demo spec in mcp_server/specs/
MODULE11_SPECS_DIR=
MODULE11_MCP_TRANSPORT=stdio
MODULE11_MCP_TIMEOUT=20

# Optional stdio override. By default the Module 11 agent launches:
#   <current-python> -m mcp_server.server --transport stdio [--specs-dir ...]
MODULE11_MCP_COMMAND=
MODULE11_MCP_ARGS=

# Remote streamable HTTP mode (used when MODULE11_MCP_TRANSPORT=streamable-http)
MODULE11_MCP_HTTP_URL=http://127.0.0.1:8765/mcp
MODULE11_MCP_HTTP_READ_TIMEOUT=300
# MODULE11_MCP_HTTP_HEADERS_JSON={"Authorization":"Bearer demo-token"}

# Server-side defaults when you run python -m mcp_server.server directly
MODULE11_SERVER_TRANSPORT=stdio
MODULE11_MCP_HOST=127.0.0.1
MODULE11_MCP_PORT=8765
MODULE11_MCP_HTTP_PATH=/mcp

# Module 12 A2A specialist URL (local banking assistant -> remote fixed-income peer)
MODULE12_A2A_SPECIALIST_URL=http://127.0.0.1:8720
# Optional: default bind port for ./a2a_agent/run_a2a_specialist_server.sh when PORT is unset
# MODULE12_SPECIALIST_PORT=8720
# Optional: default port for Module 12 standalone API (run_a2a_api_server.sh / run_a2a_api.sh when API_BASE unset)
# MODULE12_API_PORT=8726

# Module 14 — DatabaseSessionService for retail deposit agent (db_persist/14)
# Default: sqlite+aiosqlite file next to db_persist/14/main.py (module14_sessions.db)
# Use async SQLite URL form (not plain sqlite:///) for SQLAlchemy asyncio:
# MODULE14_DB_URL=sqlite+aiosqlite:////absolute/path/to/module14_sessions.db
MODULE14_DB_URL=

# Module 14A — persistent spending coach on PostgreSQL (db_persist/14A)
# Default code path targets local Docker Postgres on port 6433:
# MODULE14A_DB_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:6433/adk_sessions
MODULE14A_DB_URL=
# Default schema/search_path for ADK-created session tables:
MODULE14A_DB_SCHEMA=adk_module14a
# Session key scope:
# - customer (default): consolidate per customer across CLI/API callers
# - user: isolate by caller-provided user_id
MODULE14A_SESSION_SCOPE=customer
# Optional: default standalone API port used by db_persist/14A scripts when PORT/API_BASE are unset
# MODULE14A_API_PORT=8740