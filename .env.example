# Base URL of your LiteLLM/OpenAI-compatible endpoint.
# Both of these forms work:
#   http://127.0.0.1:4000
#   http://127.0.0.1:4000/v1
LITELLM_API_BASE=http://127.0.0.1:4000/v1

# API key for the endpoint.
# If your local proxy ignores auth, you can still leave a dummy value like "not-needed".
LITELLM_API_KEY=not-needed

# The model name exactly as your endpoint expects it in chat/completions.
LITELLM_MODEL=gemini-3-flash-preview

# Optional: mirrors the max_tokens field from your curl payload.
LITELLM_MAX_TOKENS=32

# Optional: provider prefix used by LiteLLM. For OpenAI-compatible endpoints, keep "openai".
LITELLM_PROVIDER=openai

# Optional: ADK app name shown in session metadata.
ADK_APP_NAME=simple_litellm_agent

# Optional: system instruction for the demo agent.
AGENT_INSTRUCTION=You are a helpful beginner demo agent built with Google ADK. Answer clearly and briefly.

# Optional: CORS origins for the agent API.
AGENT_API_CORS_ORIGINS=http://localhost:8513,http://127.0.0.1:8513

# Meteosource free API key for Module 05 (advanced_agent / weather tools).
# https://www.meteosource.com/client/#pricing
WEATHER_API_KEY=